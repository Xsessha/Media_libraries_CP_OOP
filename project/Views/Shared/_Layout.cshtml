@* Views/Shared/_Layout.cshtml — XSenoMusic Main Layout *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — XSenoMusic</title>
    <meta name="description" content="XSenoMusic — Your personal music streaming experience" />
    <link rel="stylesheet" href="~/css/xsenomusic.css" />
</head>
<body>
    <div class="app-layout">
        @* ===== LEFT SIDEBAR ===== *@
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon">♫</div>
                <h1>Xeno<span class="logo-accent">Music</span></h1>
            </div>

            <nav class="sidebar-nav">
                <a href="/">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    <span>Home</span>
                </a>
                <a href="/Media">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                    <span>Library</span>
                </a>
                <a href="/Playlist">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                    <span>Playlists</span>
                </a>
                <a href="/Favorites">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                    <span>Favorites</span>
                </a>
                <a href="/Profile">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    <span>Profile</span>
                </a>
                <a href="/Playback/History">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    <span>History</span>
                </a>
            </nav>

            <div class="sidebar-footer">
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <div class="sidebar-user">
                        <span class="sidebar-username">@User.Identity.Name</span>
                        <form method="post" action="/Account/Logout">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-secondary" style="width: 100%;">Sign out</button>
                        </form>
                    </div>
                }
                else
                {
                    <a href="/Account/Login" class="btn-primary" style="width: 100%; text-align: center;">Sign in</a>
                }
                <p style="margin-top: 12px;">&copy; 2025 XSenoMusic</p>
            </div>
        </aside>

        @* ===== MAIN CONTENT ===== *@
        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    @* ===== BOTTOM PLAYER ===== *@
    <div class="bottom-player" id="music-player">
        <div class="player-left">
            <img id="player-cover" class="player-cover" src="/media/default-cover.png" alt="Cover" style="display:none;" />
            <div class="player-track-info">
                <div class="player-title" id="player-title">No track selected</div>
                <div class="player-artist" id="player-artist"></div>
            </div>
        </div>

        <div class="player-center">
            <div class="player-controls">
                <button class="btn-shuffle" id="btn-shuffle" onclick="PlayerState.toggleShuffle()" title="Shuffle">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
                </button>
                <button onclick="PlayerState.prevTrack()" title="Previous">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="19 20 9 12 19 4 19 20"/><line x1="5" y1="19" x2="5" y2="5"/></svg>
                </button>
                <button onclick="PlayerState.stop()" title="Stop">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="6" width="12" height="12"/></svg>
                </button>
                <button class="btn-play-main" id="btn-play-pause" onclick="PlayerState.togglePlay()" title="Play/Pause">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                </button>
                <button onclick="PlayerState.nextTrack()" title="Next">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 4 15 12 5 20 5 4"/><line x1="19" y1="5" x2="19" y2="19"/></svg>
                </button>
            </div>
            <div class="player-progress">
                <span class="time" id="current-time">0:00</span>
                <div class="progress-bar-container" id="progress-bar">
                    <div class="progress-bar-fill" id="progress-fill" style="width: 0%"></div>
                </div>
                <span class="time" id="total-time">0:00</span>
            </div>
        </div>

        <div class="player-right">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
            <div class="volume-bar" id="volume-bar">
                <div class="volume-fill" id="volume-fill" style="width: 70%"></div>
            </div>
        </div>
    </div>

    <script src="~/js/xsenomusic.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
