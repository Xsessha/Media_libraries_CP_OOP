@model IEnumerable<MediaLibraryWebApp.Models.MediaItem>
@using System.Web

@{
    ViewData["Title"] = "Library";
    var tracksList = Model?.ToList() ?? new List<MediaLibraryWebApp.Models.MediaItem>();
}

<div class="animate-fade-in">
    @* ===== HEADER ТА ПОШУК ===== *@
    <div class="page-header">
        <h2>Library</h2>
    </div>

    <form method="get" class="toolbar">
        <div class="search-bar">
            <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input name="q" type="text" value="@ViewData["SearchQuery"]" placeholder="Search tracks or artists..." />
        </div>

        <select name="sort" class="sort-select" onchange="this.form.submit()">
            <option value="title" @(ViewData["Sort"]?.ToString() == "title" ? "selected" : "")>Sort by Title</option>
            <option value="rating" @(ViewData["Sort"]?.ToString() == "rating" ? "selected" : "")>Sort by Rating</option>
            <option value="plays" @(ViewData["Sort"]?.ToString() == "plays" ? "selected" : "")>Sort by Plays</option>
        </select>
    </form>

    @* ===== ТАБЛИЦЯ ТРЕКІВ ===== *@
    <table class="track-table">
        <thead>
            <tr>
                <th style="width: 40px">#</th>
                <th>TITLE</th>
                <th>GENRE</th>
                <th>PLAYS</th>
                <th>RATING</th>
                <th style="width: 100px"></th> @* Кнопки дій *@
            </tr>
        </thead>
        <tbody>
            @if (tracksList.Any())
            {
                for (int i = 0; i < tracksList.Count; i++)
                {
                    var track = tracksList[i];
                    var coverUrl = "https://picsum.photos/seed/" + track.Id + "/300/300";
                    var rating = (int)Math.Round(track.AverageRating);

                    <tr class="track-row" onclick="playFromLibrary(@i)" style="cursor: pointer;">
                        <td class="text-muted">@(i + 1)</td>
                        <td>
                            <div class="track-info" style="display: flex; align-items: center; gap: 10px;">
                                <img class="track-cover" src="@coverUrl" alt="Cover" style="width: 40px; height: 40px; border-radius: 4px;" />
                                <div>
                                    <div class="track-title" style="font-weight: bold;">@track.Title</div>
                                    <div class="track-artist" style="font-size: 0.85em; color: #aaa;">@track.Artist</div>
                                    @* ВИПРАВЛЕНО: Звідси видалена зайва дужка "}", яка все ламала *@
                                </div>
                            </div>
                        </td>
                        <td class="track-genre">@track.Genre</td>
                        <td class="track-plays">@track.PlayCount</td>
                        <td>
                            <div class="rating-stars" style="display: flex; gap: 2px;">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    var starLevel = s;
                                    <span class="star @(s <= rating ? "filled" : "")" onclick="event.stopPropagation(); setRating('@track.Id', @starLevel)" style="cursor:pointer;">
                                        @if (s <= rating) {
                                            <svg viewBox="0 0 24 24" width="18" height="18" fill="#facc15"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                        } else {
                                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#666" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                        }
                                    </span>
                                }
                            </div>
                        </td>
                        <td class="track-actions">
                            <div style="display: flex; gap: 15px; align-items: center; justify-content: flex-end; padding-right: 15px;">
                                <button class="btn-favorite" onclick="event.stopPropagation(); Favorites.toggle('@track.Id')" style="background: none; border: none; color: white; cursor: pointer;">
                                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                                </button>
                                <button class="btn-play-sm" onclick="event.stopPropagation(); playFromLibrary(@i)" style="background: none; border: none; color: white; cursor: pointer;">
                                    <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        // ВИПРАВЛЕНО: Створення черги без червоних підкреслень у Visual Studio
        var libraryTracks = [
            @foreach (var t in tracksList) {
                <text>
                {
                    filename: "@Html.Raw(HttpUtility.JavaScriptStringEncode(t.Filename ?? ""))",
                    title: "@Html.Raw(HttpUtility.JavaScriptStringEncode(t.Title ?? "Unknown"))",
                    artist: "@Html.Raw(HttpUtility.JavaScriptStringEncode(t.Artist ?? "Unknown Artist"))",
                    coverPath: "https://picsum.photos/seed/@t.Id/300/300"
                },
                </text>
            }
        ];

        // Функція запуску з Library
        function playFromLibrary(index) {
            if (window.PlayerState && typeof window.PlayerState.playQueue === 'function') {
                window.PlayerState.playQueue(libraryTracks, index);
            } else {
                console.warn("PlayerState is not ready.");
            }
        }

        // Заглушки, щоб уникнути помилок JS при кліку (сюди додаш логіку запитів до сервера)
        var Favorites = {
            toggle: function(id) {
                console.log("Toggle favorite for ID:", id);
                // fetch('/Favorites/Toggle', { method: 'POST', body: 'id=' + id });
            }
        };

        function setRating(id, rating) {
            console.log("Set rating " + rating + " for ID:", id);
            // fetch('/Rating/Set', { method: 'POST', body: 'id=' + id + '&rating=' + rating });
        }
    </script>
}