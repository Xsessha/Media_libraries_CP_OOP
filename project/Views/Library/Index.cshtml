@model IEnumerable<MediaLibraryWebApp.Models.MediaItem>
@using System.Web

@{
    ViewData["Title"] = "Library";
    // Використовуємо Model безпосередньо, щоб створити локальний список
    var tracksList = Model?.ToList() ?? new List<MediaLibraryWebApp.Models.MediaItem>();
}

<div class="animate-fade-in">
    @* ===== HEADER ТА ПОШУК (ПОВЕРНЕНО) ===== *@
    <div class="page-header">
        <h2>Library</h2>
    </div>

    <form method="get" class="toolbar">
        <div class="search-bar">
            <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input name="q" type="text" value="@ViewData["SearchQuery"]" placeholder="Search tracks or artists..." />
        </div>

        <select name="sort" class="sort-select" onchange="this.form.submit()">
            <option value="title" @(ViewData["Sort"]?.ToString() == "title" ? "selected" : "")>Sort by Title</option>
            <option value="rating" @(ViewData["Sort"]?.ToString() == "rating" ? "selected" : "")>Sort by Rating</option>
            <option value="plays" @(ViewData["Sort"]?.ToString() == "plays" ? "selected" : "")>Sort by Plays</option>
        </select>
    </form>

    @* ===== ТАБЛИЦЯ ТРЕКІВ (ВІДНОВЛЕНО СТИЛЬ) ===== *@
    <table class="track-table">
        <thead>
            <tr>
                <th style="width: 40px">#</th>
                <th>TITLE</th>
                <th>GENRE</th>
                <th>PLAYS</th>
                <th>RATING</th>
                <th style="width: 100px"></th> @* Кнопки дій праворуч *@
            </tr>
        </thead>
        <tbody>
            @if (tracksList.Any())
            {
                for (int i = 0; i < tracksList.Count; i++)
                {
                    var track = tracksList[i];
                    var img = $"https://picsum.photos/seed/{track.Id}/300/300";

                    <tr class="track-row" onclick="playFromLibrary(@i)" style="cursor: pointer;">
                        <td class="text-muted">@(i + 1)</td>
                        <td>
                            <div class="track-info">
                                <img class="track-cover" src="@img" alt="Cover" />
                                <div>
                                    <div class="track-title">@track.Title</div>
                                    <div class="track-artist">@track.Artist</div>
                                </div>
                            </div>
                        </td>
                        <td class="track-genre">@track.Genre</td>
                        <td class="track-plays">@track.PlayCount</td>
                        <td>
                            <div class="rating-stars">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    var starLevel = s;
                                    @* ВИПРАВЛЕНО: Зірочки тепер викликають setRating *@
                                    <span class="star @(s <= Math.Round(track.AverageRating) ? "filled" : "")" onclick="event.stopPropagation(); setRating('@track.Id', @starLevel)">
                                        @if (s <= Math.Round(track.AverageRating)) {
                                            <svg viewBox="0 0 24 24" fill="#facc15"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                        } else {
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                        }
                                    </span>
                                }
                            </div>
                        </td>
                        <td class="track-actions">
                            @* Кнопка Плей *@
                            <button class="btn-play-sm" onclick="event.stopPropagation(); playFromLibrary(@i)">
                                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                            </button>
                            @* ВИПРАВЛЕНО: Кнопка сердечка праворуч і працює *@
                            <button class="btn-favorite" onclick="event.stopPropagation(); Favorites.toggle('@track.Id')">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                            </button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        // Створюємо масив пісень для плеєра БЕЗ помилкового CoverPath
        var libraryTracks = [];
        
        @foreach (var t in tracksList) {
            @:libraryTracks.push({
                @:filename: "@Html.Raw(HttpUtility.JavaScriptStringEncode(t.Filename ?? ""))",
                @:title: "@Html.Raw(HttpUtility.JavaScriptStringEncode(t.Title ?? "Unknown"))",
                @:artist: "@Html.Raw(HttpUtility.JavaScriptStringEncode(t.Artist ?? "Unknown Artist"))",
                @:coverPath: "https://picsum.photos/seed/@t.Id/300/300"
            @:});
        }

        function playFromLibrary(index) {
            if (window.PlayerState && typeof window.PlayerState.playQueue === 'function') {
                window.PlayerState.playQueue(libraryTracks, index);
            }
        }
    </script>
}