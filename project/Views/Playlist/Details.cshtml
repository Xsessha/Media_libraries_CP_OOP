@model MediaLibraryWebApp.Models.Playlist

@{
    ViewData["Title"] = "Playlist Details";
    var playlist = Model;
    var availableMedia = ViewData["AvailableMedia"] as List<MediaLibraryWebApp.Models.MediaItem> ?? new List<MediaLibraryWebApp.Models.MediaItem>();
}

<div class="animate-fade-in">
    
    <div class="page-header-row" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2 style="margin: 0;">@playlist?.Name</h2>
        
        <div style="display: flex; gap: 15px; align-items: center;">
            
            @if (playlist?.Tracks != null && playlist.Tracks.Any())
            {
                var trackList = playlist.Tracks
                    .Where(t => t.MediaItem != null)
                    .OrderBy(t => t.Position)
                    .Select(t => new {
                        title = t.MediaItem.Title ?? "Unknown",
                        artist = t.MediaItem.Artist ?? "Unknown",
                        filename = t.MediaItem.Filename ?? "",
                        // УВАГА: Якщо ваша колонка з картинкою називається не ImagePath, змініть її тут!
                        coverPath = ""
                    }).ToList();

                var jsonTracks = System.Text.Json.JsonSerializer.Serialize(trackList);

                <button data-tracks="@jsonTracks" 
                        onclick="startPlaylistFromButton(this)" 
                        class="btn" 
                        style="background-color: #1ed760; color: #000; font-weight: bold; border-radius: 50%; width: 45px; height: 45px; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;"
                        title="Play Playlist">
                    <span style="font-size: 20px; margin-left: 4px;">▶</span>
                </button>
            }

            <a href="/Playlist" class="btn" style="background-color: #1ed760; color: #000; font-weight: bold; border-radius: 20px; padding: 6px 20px; text-decoration: none; font-size: 14px;">
                Save
            </a>

            @if (playlist != null)
            {
                <form method="post" action="/Playlist/Delete" style="margin: 0;">
                    <input type="hidden" name="id" value="@playlist.Id" />
                    <button class="btn-secondary" type="submit" style="border-radius: 20px; padding: 6px 20px;">Delete Playlist</button>
                </form>
            }
        </div>
    </div>

    <div class="section">
        <h3>Tracks (@(playlist?.Tracks?.Count ?? 0))</h3>
        @if (playlist?.Tracks == null || !playlist.Tracks.Any())
        {
            <p>No tracks yet. Add some below.</p>
        }
        else
        {
            <table class="track-table" style="width:100%; margin-bottom:20px;">
                <thead>
                    <tr><th>#</th><th>Title</th><th>Artist</th><th>Genre</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var track in playlist.Tracks.Where(t => t.MediaItem != null).OrderBy(t => t.Position))
                    {
                        <tr>
                            <td>@track.Position</td>
                            <td>@track.MediaItem.Title</td>
                            <td>@track.MediaItem.Artist</td>
                            <td>@track.MediaItem.Genre</td>
                            <td>
                                <form method="post" action="/Playlist/RemoveTrack" style="display:inline;">
                                    <input type="hidden" name="playlistId" value="@playlist.Id" />
                                    <input type="hidden" name="mediaItemId" value="@track.MediaItemId" />
                                    <button type="submit" class="btn-secondary" style="font-size:11px;">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="section">
        <h3>Add Track to Playlist</h3>
        @if (!availableMedia.Any())
        {
            <p>All media are already in this playlist.</p>
        }
        else
        {
            <table class="track-table" style="width:100%;">
                <thead>
                    <tr><th>Title</th><th>Artist</th><th>Genre</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var track in availableMedia)
                    {
                        <tr>
                            <td>@track.Title</td>
                            <td>@track.Artist</td>
                            <td>@track.Genre</td>
                            <td>
                                <form method="post" action="/Playlist/AddTrack" style="display:inline;">
                                    <input type="hidden" name="playlistId" value="@playlist?.Id" />
                                    <input type="hidden" name="mediaItemId" value="@track.Id" />
                                    <button type="submit" class="btn-primary" style="font-size:11px;">Add</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="section">
        <a href="/Media" class="btn-secondary">Back to Library</a>
    </div>
</div>

<script>
    let playlistQueue = [];
    let currentQueueIndex = 0;
    let playlistAudio = null; 
    let isPlaylistMode = false;

    let originalTogglePlay = null;
    let originalNext = null;
    let originalPrev = null;
    let originalStop = null;

    function hookPlayerControls() {
        if (typeof PlayerState !== 'undefined' && !originalTogglePlay) {
            originalTogglePlay = PlayerState.togglePlay;
            originalNext = PlayerState.nextTrack;
            originalPrev = PlayerState.prevTrack;
            originalStop = PlayerState.stop;

            PlayerState.togglePlay = function() {
                if (isPlaylistMode && playlistAudio) {
                    if (playlistAudio.paused) {
                        playlistAudio.play();
                        document.getElementById('player-status').innerText = "Playing...";
                    } else {
                        playlistAudio.pause();
                        document.getElementById('player-status').innerText = "Paused";
                    }
                } else if (originalTogglePlay) {
                    originalTogglePlay.apply(PlayerState);
                }
            };

            PlayerState.nextTrack = function() {
                if (isPlaylistMode) {
                    currentQueueIndex++;
                    playCurrentQueueTrack();
                } else if (originalNext) {
                    originalNext.apply(PlayerState);
                }
            };

            PlayerState.prevTrack = function() {
                if (isPlaylistMode) {
                    currentQueueIndex--;
                    if (currentQueueIndex < 0) currentQueueIndex = 0;
                    playCurrentQueueTrack();
                } else if (originalPrev) {
                    originalPrev.apply(PlayerState);
                }
            };

            PlayerState.stop = function() {
                if (isPlaylistMode && playlistAudio) {
                    playlistAudio.pause();
                    playlistAudio.currentTime = 0;
                    document.getElementById('player-status').innerText = "Stopped";
                    isPlaylistMode = false;
                } else if (originalStop) {
                    originalStop.apply(PlayerState);
                }
            };
        }
    }

    function startPlaylistFromButton(buttonElement) {
        try {
            let rawData = buttonElement.getAttribute('data-tracks');
            let tracks = JSON.parse(rawData);
            playPlaylist(tracks);
        } catch (error) {
            console.error("Помилка при читанні списку треків:", error);
            alert("Не вдалося прочитати дані плейлиста.");
        }
    }

    function playPlaylist(tracks) {
        if (!tracks || tracks.length === 0) {
            alert("Плейлист порожній!");
            return;
        }

        playlistQueue = tracks;
        currentQueueIndex = 0;
        isPlaylistMode = true; 
        
        hookPlayerControls(); 
        playCurrentQueueTrack();
    }

    function playCurrentQueueTrack() {
        if (currentQueueIndex >= playlistQueue.length) {
            document.getElementById('player-status').innerText = "Playlist Completed";
            isPlaylistMode = false; 
            return;
        }

        if (currentQueueIndex < 0) currentQueueIndex = 0;

        let track = playlistQueue[currentQueueIndex];
        
        if (!playlistAudio) {
            playlistAudio = document.querySelector('audio');
            if (!playlistAudio) {
                playlistAudio = document.createElement('audio');
                playlistAudio.id = 'global-audio-player';
                document.body.appendChild(playlistAudio);
            }
        }

        playlistAudio.src = "/media/" + track.filename; 

        document.getElementById('player-title').innerText = track.title;
        document.getElementById('player-artist').innerText = track.artist;
        document.getElementById('player-status').innerText = "Playing...";
        
        // ОНОВЛЕННЯ КАРТИНКИ
        let cover = document.getElementById('player-cover');
        if (cover) {
            if (track.coverPath) {
                cover.src = track.coverPath; // Підставляємо шлях до картинки
            } else {
                cover.src = "/images/default-cover.png"; // Стандартна заглушка (якщо є)
            }
            cover.style.display = 'block';
        }

        playlistAudio.play().catch(error => {
            console.warn("Браузер блокує автовідтворення. Натисніть на сторінку.");
        });

        playlistAudio.onended = function() {
            if (isPlaylistMode) {
                currentQueueIndex++;
                playCurrentQueueTrack();
            }
        };

        playlistAudio.ontimeupdate = function() {
            if (!isPlaylistMode) return; 

            let currentTimeEl = document.getElementById('current-time');
            let totalTimeEl = document.getElementById('total-time');
            let progressFill = document.getElementById('progress-fill');
            
            if (currentTimeEl) {
                let mins = Math.floor(playlistAudio.currentTime / 60);
                let secs = Math.floor(playlistAudio.currentTime % 60).toString().padStart(2, '0');
                currentTimeEl.innerText = `${mins}:${secs}`;
            }
            
            if (progressFill && playlistAudio.duration) {
                let percent = (playlistAudio.currentTime / playlistAudio.duration) * 100;
                progressFill.style.width = percent + '%';
                
                let totalMins = Math.floor(playlistAudio.duration / 60);
                let totalSecs = Math.floor(playlistAudio.duration % 60).toString().padStart(2, '0');
                if (totalTimeEl && !isNaN(totalMins)) {
                    totalTimeEl.innerText = `${totalMins}:${totalSecs}`;
                }
            }
        };
    }
</script>