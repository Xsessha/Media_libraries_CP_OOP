@model MediaLibraryWebApp.Models.Playlist

@{
    ViewData["Title"] = "Playlist Details";
    var playlist = Model;
    var availableMedia = ViewData["AvailableMedia"] as List<MediaLibraryWebApp.Models.MediaItem> ?? new List<MediaLibraryWebApp.Models.MediaItem>();
    
    var playlistTracks = playlist?.Tracks?.Where(t => t.MediaItem != null)
        .OrderBy(t => t.Position)
        .ToList() ?? new List<MediaLibraryWebApp.Models.PlaylistTrack>();
}

<div class="animate-fade-in">
    
    <div class="page-header-row" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <div>
            <h2 style="margin: 0;">@playlist?.Name</h2>

            @* ⭐ WEEKLY LABEL *@
            @if (playlist != null && playlist.Name.Contains("Weekly"))
            {
                <div style="margin-top:5px; color:#1ed760; font-weight:bold;">
                    ⭐ Auto-generated Weekly Playlist
                </div>
            }
        </div>
        
        <div style="display: flex; gap: 15px; align-items: center;">
            
            @* ▶ PLAY BUTTON *@
            @if (playlistTracks.Any())
            {
                <button onclick="playFromPlaylist(0)" 
                        class="btn" 
                        style="background-color: #1ed760; color: #000; font-weight: bold; border-radius: 50%; width: 45px; height: 45px; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;"
                        title="Play Playlist">
                    <span style="font-size: 20px; margin-left: 4px;">▶</span>
                </button>
            }

            @* 🔥 WEEKLY GENERATE BUTTON *@
            <a href="/Playlist/GenerateWeekly?userId=1"
               class="btn"
               style="background-color:#1ed760; color:#000; font-weight:bold; border-radius:20px; padding:6px 20px; text-decoration:none; font-size:14px;">
                Generate Weekly Mix
            </a>

            @* SAVE *@
            <a href="/Playlist" class="btn" style="background-color: #1ed760; color: #000; font-weight: bold; border-radius: 20px; padding: 6px 20px; text-decoration: none; font-size: 14px;">
                Save
            </a>

            @* DELETE *@
            @if (playlist != null)
            {
                <form method="post" action="/Playlist/Delete" style="margin: 0;">
                    <input type="hidden" name="id" value="@playlist.Id" />
                    <button class="btn-secondary" type="submit" style="border-radius: 20px; padding: 6px 20px;">
                        Delete Playlist
                    </button>
                </form>
            }
        </div>
    </div>

    <div class="section">
        <h3>Tracks (@playlistTracks.Count)</h3>

        @* ⭐ WEEKLY DESCRIPTION *@
        @if (playlist != null && playlist.Name.Contains("Weekly"))
        {
            <p style="color:gray;">
                This playlist was automatically generated based on your most played tracks from the last 7 days.
            </p>
        }

        @if (!playlistTracks.Any())
        {
            <p>No tracks yet. Add some below.</p>
        }
        else
        {
            <table class="track-table" style="width:100%; margin-bottom:20px;">
                <thead>
                    <tr>
                        <th style="width: 40px">#</th>
                        <th>Title</th>
                        <th>Artist</th>
                        <th>Genre</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < playlistTracks.Count; i++)
                    {
                        var track = playlistTracks[i];
                        <tr onclick="playFromPlaylist(@i)" style="cursor: pointer;">
                            <td>@track.Position</td>
                            <td>@track.MediaItem.Title</td>
                            <td>@track.MediaItem.Artist</td>
                            <td>@track.MediaItem.Genre</td>
                            <td>
                                <button class="btn-play-sm" onclick="event.stopPropagation(); playFromPlaylist(@i)" style="background: none; border: none; color: white; cursor: pointer; margin-right: 10px;">
                                    ▶
                                </button>
                                <form method="post" action="/Playlist/RemoveTrack" style="display:inline;">
                                    <input type="hidden" name="playlistId" value="@playlist.Id" />
                                    <input type="hidden" name="mediaItemId" value="@track.MediaItemId" />
                                    <button type="submit" onclick="event.stopPropagation();" class="btn-secondary" style="font-size:11px;">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="section">
        <h3>Add Track to Playlist</h3>

        @if (!availableMedia.Any())
        {
            <p>All media are already in this playlist.</p>
        }
        else
        {
            <table class="track-table" style="width:100%;">
                <thead>
                    <tr><th>Title</th><th>Artist</th><th>Genre</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var track in availableMedia)
                    {
                        <tr>
                            <td>@track.Title</td>
                            <td>@track.Artist</td>
                            <td>@track.Genre</td>
                            <td>
                                <form method="post" action="/Playlist/AddTrack" style="display:inline;">
                                    <input type="hidden" name="playlistId" value="@playlist?.Id" />
                                    <input type="hidden" name="mediaItemId" value="@track.Id" />
                                    <button type="submit" class="btn-primary" style="font-size:11px;">Add</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="section">
        <a href="/Media" class="btn-secondary">Back to Library</a>
    </div>
</div>

@section Scripts {
    <script>
        var currentPlaylistTracks = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            playlistTracks.Select(t => new {
                id = t.MediaItem.Id,
                filename = t.MediaItem.Filename ?? "",
                title = t.MediaItem.Title ?? "Unknown",
                artist = t.MediaItem.Artist ?? "Unknown",
                coverPath = $"https://picsum.photos/seed/{t.MediaItem.Id}/300/300"
            })
        ));

        function playFromPlaylist(index) {
            if (window.PlayerState && typeof window.PlayerState.playQueue === 'function') {
                window.PlayerState.playQueue(currentPlaylistTracks, index);
            } else {
                console.error("PlayerState is not ready.");
            }
        }
    </script>
}