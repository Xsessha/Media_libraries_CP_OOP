@model IEnumerable<MediaLibraryWebApp.Models.PlaybackHistory>

@{
    ViewData["Title"] = "History";
    var entries = Model?.ToList() ?? new List<MediaLibraryWebApp.Models.PlaybackHistory>();
}

<div class="animate-fade-in">
    <div class="page-header">
        <h2>Listening History</h2>
    </div>

    @if (!entries.Any())
    {
        <div class="empty-state">
            <p>No history yet. Play a track to start logging your listen history.</p>
        </div>
    }
    else
    {
        <div class="history-grid">
            @foreach (var entry in entries)
            {
                if (entry.MediaItem == null)
                {
                    <div class="history-row">
                        <div class="history-info">
                            <div class="history-title">Unknown track</div>
                            <div class="history-artist">(removed)</div>
                        </div>
                        <span class="history-time">@entry.DatePlayed.ToString("MMM d, yyyy · h:mm tt")</span>
                    </div>
                }
                else
                {
                    <div class="history-row" onclick="playTrack('@entry.MediaItem.Id', '@entry.MediaItem.Filename', '@entry.MediaItem.Title', '@entry.MediaItem.Artist', 'https://picsum.photos/seed/@entry.MediaItem.Id/300/300')">
                        <img class="history-cover" src="https://picsum.photos/seed/@entry.MediaItem.Id/80/80" alt="" />
                        <div class="history-info">
                            <div class="history-title">@entry.MediaItem.Title</div>
                            <div class="history-artist">@entry.MediaItem.Artist</div>
                        </div>
                        <span class="history-time">@entry.DatePlayed.ToString("MMM d, yyyy · h:mm tt")</span>
                    </div>
                }
            }
        </div>
    }
</div>
