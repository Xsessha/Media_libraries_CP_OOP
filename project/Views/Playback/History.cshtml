@model IEnumerable<MediaLibraryWebApp.Models.PlaybackHistory>

@{
    ViewData["Title"] = "History";
    var entries = Model?.ToList() ?? new List<MediaLibraryWebApp.Models.PlaybackHistory>();
}

<div class="animate-fade-in">
    <div class="page-header">
        <h2>Listening History</h2>
    </div>

    @if (!entries.Any())
    {
        <div class="empty-state">
            <p>No history yet. Play a track to start logging your listen history.</p>
        </div>
    }
    else
    {
        <div class="history-grid">
            @foreach (var entry in entries)
            {
                if (entry?.MediaItem == null)
                {
                    <div class="history-row" style="opacity: 0.5; cursor: not-allowed;">
                        <div class="history-info">
                            <div class="history-title">Unknown track</div>
                            <div class="history-artist">(removed)</div>
                        </div>
                        <span class="history-time">@entry.DatePlayed.ToString("MMM d, yyyy · h:mm tt")</span>
                    </div>
                }
                else
                {
                    var safeTitle = entry.MediaItem.Title?.Replace("'", "\\'") ?? "Unknown";
                    var safeArtist = entry.MediaItem.Artist?.Replace("'", "\\'") ?? "Unknown";

                    <div class="history-row"
                         onclick="playSingleTrack('@entry.MediaItem.Id', '@entry.MediaItem.Filename', '@safeTitle', '@safeArtist', 'https://picsum.photos/seed/@entry.MediaItem.Id/300/300')"
                         style="cursor: pointer;">

                        <img class="history-cover"
                             src="https://picsum.photos/seed/@entry.MediaItem.Id/80/80" />

                        <div class="history-info">
                            <div class="history-title">@entry.MediaItem.Title</div>
                            <div class="history-artist">@entry.MediaItem.Artist</div>
                        </div>

                        <span class="history-time">
                            @entry.DatePlayed.ToString("MMM d, yyyy · h:mm tt")
                        </span>
                    </div>
                }
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        function playSingleTrack(id, filename, title, artist, cover) {
            var singleTrackQueue = [{
                id: id,
                filename: filename,
                title: title,
                artist: artist,
                coverPath: cover
            }];

            if (window.PlayerState && window.PlayerState.playQueue) {
                window.PlayerState.playQueue(singleTrackQueue, 0);
            } else {
                console.error("PlayerState is not ready.");
            }
        }
    </script>
}