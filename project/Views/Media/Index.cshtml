@model IEnumerable<MediaLibraryWebApp.Models.MediaItem>
@using System

@{
    ViewData["Title"] = "Library";
    var tracks = Model?.ToList() ?? new List<MediaLibraryWebApp.Models.MediaItem>();
}

<div class="animate-fade-in">
    <div class="page-header">
        <h2>Library</h2>
    </div>

    <form method="get" class="toolbar">
        <div class="search-bar">
            <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input name="q" type="text" value="@ViewData["SearchQuery"]" placeholder="Search tracks or artists..." />
        </div>

        <select name="sort" class="sort-select" onchange="this.form.submit()">
            <option value="title" @(ViewData["Sort"]?.ToString() == "title" ? "selected" : "")>Sort by Title</option>
            <option value="rating" @(ViewData["Sort"]?.ToString() == "rating" ? "selected" : "")>Sort by Rating</option>
            <option value="date" @(ViewData["Sort"]?.ToString() == "date" ? "selected" : "")>Sort by Date Added</option>
        </select>
    </form>

    <table class="track-table" id="track-table">
        <thead>
            <tr>
                <th style="width: 40px">#</th>
                <th>Title</th>
                <th>Genre</th>
                <th>Rating</th>
                <th style="width: 60px"></th>
                <th style="width: 40px"></th>
            </tr>
        </thead>
        <tbody>
            @if (tracks.Any())
            {
                var index = 1;
                foreach (var track in tracks)
                {
                    var coverUrl = $"https://picsum.photos/seed/{track.Id}/300/300";
                    var rating = (int)Math.Round(track.AverageRating);
                    <tr data-title="@track.Title" data-rating="@rating" data-date="@track.DateAdded:yyyy-MM-dd"
                            onclick="playTrack('@track.Id', '@track.Filename', '@track.Title', '@track.Artist', '@coverUrl')">
                        <td style="color: var(--text-muted); font-size: 13px;">@index</td>
                        <td>
                            <div class="track-info">
                                <img class="track-cover" src="@coverUrl" alt="" />
                                <div>
                                    <div class="track-title">@track.Title</div>
                                    <div class="track-artist">@track.Artist</div>
                                </div>
                            </div>
                        </td>
                        <td class="track-genre">@track.Genre</td>
                        <td>
                            <div class="rating-stars" data-track-id="@track.Id">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    var starNum = s;
                                    <span class="star @(s <= rating ? "filled" : "")" onclick="event.stopPropagation(); setRating('@track.Id', @starNum)">
                                        @if (s <= rating)
                                        {
                                            <svg viewBox="0 0 24 24" fill="#facc15" stroke="#facc15" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                        }
                                        else
                                        {
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                        }
                                    </span>
                                }
                            </div>
                        </td>
                        <td>
                            <button class="btn-play-sm" onclick="event.stopPropagation(); playTrack('@track.Id', '@track.Filename', '@track.Title', '@track.Artist', '@coverUrl')" title="Play">
                                <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                            </button>
                        </td>
                        <td>
                            <button class="btn-favorite" data-track-id="@track.Id" onclick="event.stopPropagation(); Favorites.toggle('@track.Id')" title="Favorite">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                            </button>
                        </td>
                    </tr>
                    index++;
                }
            }
            else
            {
                <tr>
                    <td colspan="6" style="text-align:center; padding: 24px; color: var(--text-muted);">
                        No tracks found. Add media items to your library to start listening.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
