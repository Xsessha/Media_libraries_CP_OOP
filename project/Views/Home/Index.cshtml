@model MediaLibraryWebApp.Models.HomeViewModel

@{
    ViewData["Title"] = "Home - XSenoMusic";
    // Перетворюємо списки в List для зручності
    var topRated = Model.TopRatedTracks.ToList();
    var recent = Model.RecentlyAdded.ToList();
    var trending = Model.MostPlayedTracks.ToList();
}

<div class="hero-section">
    <h1>Welcome to XSenoMusic</h1>
    <p>Explore our collection with @Model.TotalTracksCount tracks that have already been listened to @Model.TotalPlaysCount times!</p>
    <a href="@Url.Action("Index", "Media")" class="hero-button">Go to Library</a>
</div>

<div class="home-section">
    <h2 class="section-title">Top Rated</h2>
    <div class="card-container">
        @for (int i = 0; i < topRated.Count; i++)
        {
            var media = topRated[i];
            <div class="track-card" onclick="playFromTopRated(@i)">
                <img src="https://picsum.photos/seed/@(media.Id)/300/300" onerror="this.src='/images/default-cover.png'" alt="@media.Title cover" class="track-cover" />
                
                <div class="track-info">
                    <p class="track-title">@media.Title</p>
                    <p class="track-artist">@media.Artist</p>
                    
                    <div class="rating-stars" style="--rating: @media.AverageRating.ToString("F1")">
                        <span class="star">☆</span><span class="star">☆</span><span class="star">☆</span><span class="star">☆</span><span class="star">☆</span>
                    </div>
                </div>

                <button class="play-icon-button" onclick="event.stopPropagation(); playFromTopRated(@i)">
                    <i class="play-icon">▶</i>
                </button>
            </div>
        }
    </div>
</div>

<div class="home-section">
    <h2 class="section-title">New Releases</h2>
    <div class="card-container">
        @for (int i = 0; i < recent.Count; i++)
        {
            var media = recent[i];
            <div class="track-card" onclick="playFromRecent(@i)">
                <img src="https://picsum.photos/seed/@(media.Id)/300/300" onerror="this.src='/images/default-cover.png'" alt="@media.Title cover" class="track-cover" />
                
                <div class="track-info">
                    <p class="track-title">@media.Title</p>
                    <p class="track-artist">@media.Artist</p>
                </div>
                
                <button class="play-icon-button" onclick="event.stopPropagation(); playFromRecent(@i)">
                    <i class="play-icon">▶</i>
                </button>
            </div>
        }
    </div>
</div>

<div class="home-section">
    <h2 class="section-title">Trending Now</h2>
    <div class="card-container">
        @for (int i = 0; i < trending.Count; i++)
        {
            var media = trending[i];
            <div class="track-card" onclick="playFromTrending(@i)">
                <img src="https://picsum.photos/seed/@(media.Id)/300/300" onerror="this.src='/images/default-cover.png'" alt="@media.Title cover" class="track-cover" />
                
                <div class="track-info">
                    <p class="track-title">@media.Title</p>
                    <p class="track-artist">@media.Artist</p>
                    <p class="play-count">@media.PlayCount plays</p>
                </div>
                
                <button class="play-icon-button" onclick="event.stopPropagation(); playFromTrending(@i)">
                    <i class="play-icon">▶</i>
                </button>
            </div>
        }
    </div>
</div>

<style>
    /* Основні налаштування для сторінки */
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    .home-section { margin-bottom: 50px; }
    .section-title { color: white; border-bottom: 1px solid #333; padding-bottom: 10px; margin-bottom: 20px; font-weight: 500; }

    /* Стилі для Hero Section (банера) */
    .hero-section {
        padding: 50px 30px;
        background: linear-gradient(135deg, #222, #000);
        border-radius: 12px;
        margin-bottom: 40px;
        text-align: center;
        box-shadow: 0 4px 15px rgba(0,0,0,0.5);
    }
    .hero-section h1 { font-size: 3.5rem; margin-bottom: 15px; color: white; font-weight: 700; }
    .hero-section p { color: #ccc; margin-bottom: 25px; font-size: 1.3rem; }
    .hero-button {
        display: inline-block;
        padding: 14px 28px;
        background-color: #1db954; /* Spotify Green */
        color: white;
        text-decoration: none;
        border-radius: 25px;
        font-weight: 600;
        font-size: 1.1rem;
        transition: 0.3s;
    }
    .hero-button:hover { background-color: #1ed760; box-shadow: 0 4px 10px rgba(29,185,84,0.4); }

    /* Стилі для контейнера карток (сітка) */
    .card-container {
        display: flex;
        flex-wrap: wrap; 
        gap: 20px; 
    }

    /* Стилі для однієї картки треку */
    .track-card {
        background-color: #181818; 
        border-radius: 8px;
        padding: 15px;
        width: calc(25% - 15px); 
        text-align: left;
        cursor: pointer;
        transition: background-color 0.3s, transform 0.2s;
        position: relative;
        box-shadow: 0 4px 6px rgba(0,0,0,0.3);
    }
    .track-card:hover { background-color: #282828; transform: translateY(-3px); }

    /* Стилі для обкладинки */
    .track-cover {
        width: 100%;
        height: auto;
        aspect-ratio: 1/1; 
        object-fit: cover;
        border-radius: 4px;
        margin-bottom: 10px;
    }

    /* Стилі для тексту */
    .track-info p { margin: 0; }
    .track-title { color: white; font-weight: 600; font-size: 1.1rem; margin-bottom: 3px; }
    .track-artist { color: #aaa; font-size: 0.9rem; margin-bottom: 8px; }
    .play-count { color: #888; font-size: 0.8rem; font-style: italic; }

    /* Просунуті стилі для рейтингу зірочок з partial star логікою */
    .rating-stars {
        display: inline-block;
        position: relative;
        font-size: 18px;
        color: #333; 
        white-space: nowrap;
    }
    .rating-stars::before {
        content: '★★★★★';
        position: absolute;
        top: 0;
        left: 0;
        color: #ffd700; 
        overflow: hidden;
        width: calc(var(--rating) / 5 * 100%); 
    }
    .star { cursor: default; }

    /* Стилі для кнопки Play (іконка) */
    .play-icon-button {
        position: absolute;
        bottom: 15px;
        right: 15px;
        background-color: transparent;
        border: none;
        color: rgba(29, 185, 84, 0.7); 
        font-size: 24px;
        cursor: pointer;
        padding: 0;
        transition: transform 0.2s, color 0.2s;
        opacity: 0; 
    }
    .track-card:hover .play-icon-button { opacity: 1; transform: translateY(-5px); }
    .play-icon-button:hover { color: #1ed760; transform: scale(1.1); }
</style>

@section Scripts {
    <script>
        var topRatedTracks = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(topRated.Select(t => new {
            id = t.Id, filename = t.Filename ?? "", title = t.Title ?? "Unknown", artist = t.Artist ?? "Unknown", coverPath = $"https://picsum.photos/seed/{t.Id}/300/300"
        })));

        var recentTracks = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(recent.Select(t => new {
            id = t.Id, filename = t.Filename ?? "", title = t.Title ?? "Unknown", artist = t.Artist ?? "Unknown", coverPath = $"https://picsum.photos/seed/{t.Id}/300/300"
        })));

        var trendingTracks = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(trending.Select(t => new {
            id = t.Id, filename = t.Filename ?? "", title = t.Title ?? "Unknown", artist = t.Artist ?? "Unknown", coverPath = $"https://picsum.photos/seed/{t.Id}/300/300"
        })));

        function playFromTopRated(index) {
            if (window.PlayerState && window.PlayerState.playQueue) { window.PlayerState.playQueue(topRatedTracks, index); }
        }
        function playFromRecent(index) {
            if (window.PlayerState && window.PlayerState.playQueue) { window.PlayerState.playQueue(recentTracks, index); }
        }
        function playFromTrending(index) {
            if (window.PlayerState && window.PlayerState.playQueue) { window.PlayerState.playQueue(trendingTracks, index); }
        }
    </script>
}